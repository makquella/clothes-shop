# Telegram bot token used by /api/checkout to forward new orders to a manager chat.
# If this is missing, checkout still works in demo mode but no Telegram message is sent.
TELEGRAM_BOT_TOKEN="your_bot_token_here"

# Telegram user, group, or channel chat ID that should receive order notifications.
# Add this together with the bot token when you want real Telegram forwarding enabled.
TELEGRAM_CHAT_ID="your_chat_id_here"
